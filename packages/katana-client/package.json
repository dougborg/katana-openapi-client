{
  "name": "katana-openapi-client",
  "version": "0.0.1",
  "description": "TypeScript client for Katana Manufacturing ERP API with automatic retries, rate limiting, and pagination",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./types": {
      "import": {
        "types": "./dist/types.d.ts",
        "default": "./dist/types.js"
      },
      "require": {
        "types": "./dist/types.d.cts",
        "default": "./dist/types.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "generate": "openapi-ts",
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests",
    "format": "biome format --write src tests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "katana",
    "manufacturing",
    "erp",
    "api",
    "client",
    "openapi",
    "typescript"
  ],
  "author": "Doug Borg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/dougborg/katana-openapi-client.git",
    "directory": "packages/katana-client"
  },
  "bugs": {
    "url": "https://github.com/dougborg/katana-openapi-client/issues"
  },
  "homepage": "https://github.com/dougborg/katana-openapi-client/tree/main/packages/katana-client#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@hey-api/openapi-ts": "next",
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "tsdown": "^0.22.9",
    "typescript": "^7.0.2",
    "vitest": "^4.0.15"
  },
  "sideEffects": false
}
